{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "management.json",
  "title": "Management Events",
  "type": "object",
  "properties": {
    "planting": {
      "type": "object",
      "properties": {
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "crop": { "type": "string" },
        "density_plants_m2": { "type": "number", "minimum": 0 }
      },
      "required": ["date", "crop"]
    },
    "irrigation": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "mm": { "type": "number", "minimum": 0 }
        },
        "required": ["date", "mm"]
      }
    },
    "fertilization": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "n_kg_ha": { "type": "number", "minimum": 0 },
          "p_kg_ha": { "type": "number", "minimum": 0 }
        },
        "required": ["date"]
      }
    }
  },
  "additionalProperties": false
}


