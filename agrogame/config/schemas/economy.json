{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "economy.json",
  "title": "Economy Price Table",
  "type": "object",
  "required": ["input_costs", "crop_prices"],
  "properties": {
    "input_costs": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0 }
    },
    "crop_prices": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["base_credits_per_kg"],
        "properties": {
          "base_credits_per_kg": { "type": "number", "minimum": 0 },
          "seasonal_multipliers": {
            "type": "array",
            "items": { "type": "number", "minimum": 0 },
            "minItems": 4,
            "maxItems": 4
          }
        }
      }
    }
  }
}
