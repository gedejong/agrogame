[importlinter]
root_package = agrogame
include_external_packages = False

# Architectural rules for the agrogame codebase. See docs/adr/ADR-008
# for the layering decision and the rationale behind each contract's
# `ignore_imports` allowlist.

# Minimal pragmatic contract: keep the event system isolated from domain modules
[importlinter:contract:events_isolated]
name = Events package must not depend on domain modules
type = forbidden
source_modules =
    agrogame.events
forbidden_modules =
    agrogame.soil
    agrogame.plant
    agrogame.weather
    agrogame.atmosphere
    agrogame.sim


# Plant may depend on Soil phenology types, but Soil must not import Plant.
#
# The `ignore_imports` block records soil → plant *event-subscription*
# imports — soil runtimes subscribe to plant events and read plant stress
# helpers. These are legitimate cross-domain reads of event-payload types
# defined in the publisher's package; relocating those types into a
# shared `events.plant` package would be its own substantial refactor
# (~10 callers + reshuffled tests) and is tracked separately. The
# rationale: the listed plant modules are pure data (events) or
# stress-calculation helpers, not state-mutating logic, so the soil-side
# subscribers stay decoupled in practice.
[importlinter:contract:soil_plant_direction]
name = Soil must not depend on Plant
type = forbidden
source_modules =
    agrogame.soil
forbidden_modules =
    agrogame.plant
ignore_imports =
    agrogame.soil.canopy.module -> agrogame.plant.stress
    agrogame.soil.canopy.runtime -> agrogame.plant.events
    agrogame.soil.aggregation.runtime -> agrogame.plant.roots.events
    agrogame.soil.biopores.runtime -> agrogame.plant.roots.events
    agrogame.soil.microbes.runtime -> agrogame.plant.roots.events
    agrogame.soil.micronutrients.cycle -> agrogame.plant.events
    agrogame.soil.micronutrients.runtime -> agrogame.plant.roots.events
    agrogame.soil.nitrogen.cycle -> agrogame.plant.roots.events
    agrogame.soil.nitrogen.runtime -> agrogame.plant.events
    agrogame.soil.nitrogen.runtime -> agrogame.plant.stress
    agrogame.soil.phosphorus.cycle -> agrogame.plant.roots.events
    agrogame.soil.phosphorus.runtime -> agrogame.plant.events
    agrogame.soil.phosphorus.runtime -> agrogame.plant.stress
    agrogame.soil.redox.runtime -> agrogame.plant.roots.events
    agrogame.soil.som.runtime -> agrogame.plant.roots.events

# Atmosphere ET can depend on Weather constants, but Weather must stay independent
[importlinter:contract:weather_independence]
name = Weather should be independent of domain modules
type = forbidden
source_modules =
    agrogame.weather
forbidden_modules =
    agrogame.soil
    agrogame.plant
    agrogame.atmosphere
    agrogame.sim

# Atmosphere must not depend directly on Soil (use ports/adapters or events)
[importlinter:contract:atmosphere_independence]
name = Atmosphere should be independent of Soil
type = forbidden
source_modules =
    agrogame.atmosphere
forbidden_modules =
    agrogame.soil

# Plant should be independent of Atmosphere (decouple via params/events)
[importlinter:contract:plant_independence]
name = Plant should be independent of Atmosphere
type = forbidden
source_modules =
    agrogame.plant
forbidden_modules =
    agrogame.atmosphere

# Orchestrator must not be imported by domain modules
[importlinter:contract:sim_isolation]
name = Simulation orchestrator is top-level only
type = forbidden
source_modules =
    agrogame.soil
    agrogame.plant
    agrogame.weather
    agrogame.atmosphere
forbidden_modules =
    agrogame.sim

# Soil subdomains should not cross-reference each other (prefer events).
#
# The `ignore_imports` block records cross-subdomain imports that are
# intrinsic to the day-loop: canopy reads phenology stage to gate
# senescence; nitrogen subscribes to water events to track NO3 leaching;
# canopy subscribes to water events to detect saturated days. These are
# event-driven coupling, not state coupling — relocating the events into
# a shared package would be its own refactor.
#
# `soil.water.legacy → soil.canopy.interception` is from a soon-to-be-
# removed legacy water model and should stay flagged once that module is
# excised; for now it's whitelisted so the contract reflects the rest of
# the surface.
[importlinter:contract:soil_subdomain_independence]
name = Soil subdomains are independent (use events)
type = independence
modules =
    agrogame.soil.water
    agrogame.soil.nitrogen
    agrogame.soil.canopy
    agrogame.soil.phenology
ignore_imports =
    agrogame.soil.canopy.module -> agrogame.soil.phenology
    agrogame.soil.canopy.module -> agrogame.soil.phenology.events
    agrogame.soil.canopy.runtime -> agrogame.soil.phenology
    agrogame.soil.canopy.runtime -> agrogame.soil.water.events
    agrogame.soil.nitrogen.cycle -> agrogame.soil.water.events
    agrogame.soil.water.legacy -> agrogame.soil.canopy.interception

# Plant must not import Soil subdomains directly; use events or ports.
#
# `plant.roots.runtime → soil.phenology.PhenologyModule` is whitelisted
# because the plant root runtime reads the current phenology stage from
# the soil-side phenology runtime. Abstracting the read via a port adds
# indirection without value — `PhenologyStage` already lives in the
# neutral `agrogame.params.phenology` (#300, ADR-008); only the runtime
# *reference* remains as a known exception.
[importlinter:contract:plant_vs_soil]
name = Plant independent of Soil subdomains
type = forbidden
source_modules =
    agrogame.plant
forbidden_modules =
    agrogame.soil.water
    agrogame.soil.nitrogen
    agrogame.soil.canopy
    agrogame.soil.phenology
ignore_imports =
    agrogame.plant.roots.runtime -> agrogame.soil.phenology

# Domain layering to ensure dependency direction.
# In import-linter `layers`, EARLIER entries are HIGHER. Higher layers may
# import from lower layers; lower layers may not reach upward.
#
# Project order, derived from the existing forbidden contracts:
# - `plant_independence` says plant ↛ atmosphere ⇒ atmosphere > plant
# - `soil_plant_direction` says soil ↛ plant ⇒ plant > soil
# - `weather_independence` says weather ↛ everything ⇒ weather is lowest
# So: atmosphere (highest, ET orchestrates plant + soil + weather) >
#     plant (depends on soil shared types) > soil (depends on weather) >
#     weather (foundational).
#
# `ignore_imports` mirrors the entries on `soil_plant_direction` — the
# event-subscription pattern produces the same soil → plant edges that
# the layers contract sees as "lower importing higher".
[importlinter:contract:domain_layers]
name = Domain layers direction
type = layers
layers =
    agrogame.atmosphere
    agrogame.plant
    agrogame.soil
    agrogame.weather
ignore_imports =
    agrogame.soil.canopy.module -> agrogame.plant.stress
    agrogame.soil.canopy.runtime -> agrogame.plant.events
    agrogame.soil.aggregation.runtime -> agrogame.plant.roots.events
    agrogame.soil.biopores.runtime -> agrogame.plant.roots.events
    agrogame.soil.microbes.runtime -> agrogame.plant.roots.events
    agrogame.soil.micronutrients.cycle -> agrogame.plant.events
    agrogame.soil.micronutrients.runtime -> agrogame.plant.roots.events
    agrogame.soil.nitrogen.cycle -> agrogame.plant.roots.events
    agrogame.soil.nitrogen.runtime -> agrogame.plant.events
    agrogame.soil.nitrogen.runtime -> agrogame.plant.stress
    agrogame.soil.phosphorus.cycle -> agrogame.plant.roots.events
    agrogame.soil.phosphorus.runtime -> agrogame.plant.events
    agrogame.soil.phosphorus.runtime -> agrogame.plant.stress
    agrogame.soil.redox.runtime -> agrogame.plant.roots.events
    agrogame.soil.som.runtime -> agrogame.plant.roots.events

# ---------------------------------------------------------------------------
# Phase 4 (#297) additions
# ---------------------------------------------------------------------------

# Game layer must not depend on the API layer (one-way dependency).
# The reverse direction (api → game) is the legitimate composition path:
# the FastAPI routes wire game.economy / game.field / game.turn into a
# session, so an `api_no_game_internals` contract would block that on
# day one. Tracked as a follow-up if a public game façade is ever
# carved out.
[importlinter:contract:game_no_api]
name = Game layer must not depend on API layer
type = forbidden
source_modules =
    agrogame.game
forbidden_modules =
    agrogame.api
